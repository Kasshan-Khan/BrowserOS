// ─── Generator & Datasource ─────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum FsNodeType {
  FILE
  DIRECTORY
}

enum PermissionLevel {
  OWNER
  EDITOR
  VIEWER
}

enum AuditAction {
  // Auth
  AUTH_SIGNUP
  AUTH_LOGIN
  AUTH_LOGOUT
  AUTH_PASSWORD_RESET_REQUEST
  AUTH_PASSWORD_RESET_COMPLETE
  AUTH_SESSION_EXPIRED

  // File System
  FS_CREATE
  FS_READ
  FS_UPDATE
  FS_DELETE
  FS_MOVE
  FS_COPY
  FS_RENAME
  FS_PERMISSION_GRANT
  FS_PERMISSION_REVOKE

  // Desktop
  DESKTOP_LAYOUT_UPDATE
  DESKTOP_WALLPAPER_CHANGE

  // Admin
  ADMIN_USER_SUSPEND
  ADMIN_USER_ACTIVATE
}

// ─── Users & Authentication ──────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String     @unique
  displayName  String
  passwordHash String
  role         Role       @default(USER)
  avatarUrl    String?
  isActive     Boolean    @default(true)
  status       UserStatus @default(OFFLINE)
  statusText   String?    // Custom status message
  currentApp   String?    // Rich presence: what app they're using
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  sessions           Session[]
  passwordResetTokens PasswordResetToken[]
  desktopLayout      DesktopLayout?
  ownedFsNodes       FsNode[]             @relation("FsNodeOwner")
  fsPermissions      FsPermission[]
  windowStates       WindowState[]
  auditLogs          AuditLog[]
  friendships        Friendship[]         @relation("UserFriendships")
  friendOf           Friendship[]         @relation("FriendUser")
  sentMessages       Message[]            @relation("SentMessages")
  receivedMessages   Message[]            @relation("ReceivedMessages")
  ownedGroups        GroupChat[]           @relation("GroupOwner")
  groupMemberships   GroupMember[]
  sentTransfers      FileTransfer[]       @relation("SentTransfers")
  receivedTransfers  FileTransfer[]       @relation("ReceivedTransfers")

  @@index([email])
  @@index([username])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_reset_tokens")
}

// ─── Desktop ─────────────────────────────────────────────────────────────────

model DesktopLayout {
  id          String   @id @default(cuid())
  userId      String   @unique
  wallpaper   String   @default("default-gradient")
  iconLayout  Json     @default("[]")   // Array of { appId, x, y }
  taskbarApps Json     @default("[]")   // Array of appId strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("desktop_layouts")
}

// ─── Window Manager ──────────────────────────────────────────────────────────

model WindowState {
  id          String   @id @default(cuid())
  userId      String
  instanceId  String   // unique per window instance
  appId       String
  title       String
  x           Int      @default(100)
  y           Int      @default(100)
  width       Int      @default(800)
  height      Int      @default(600)
  isMinimized Boolean  @default(false)
  isMaximized Boolean  @default(false)
  zIndex      Int      @default(100)
  appState    Json     @default("{}")  // App-specific state (open file path, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, instanceId])
  @@index([userId])
  @@map("window_states")
}

// ─── Virtual File System ─────────────────────────────────────────────────────

model FsNode {
  id          String     @id @default(cuid())
  name        String
  type        FsNodeType
  parentId    String?
  ownerId     String
  content     String?    // For files: text content (or blob reference)
  mimeType    String?    // e.g. "text/plain", "application/json"
  size        Int        @default(0)  // bytes
  isDeleted   Boolean    @default(false)
  deletedAt   DateTime?
  path        String     // Denormalized full path for fast lookups: /home/user/docs
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Self-referential tree
  parent   FsNode?  @relation("FsTree", fields: [parentId], references: [id])
  children FsNode[] @relation("FsTree")

  // Relations
  owner       User           @relation("FsNodeOwner", fields: [ownerId], references: [id])
  permissions FsPermission[]

  @@index([parentId])
  @@index([ownerId])
  @@index([path])
  @@index([isDeleted])
  @@map("fs_nodes")
}

model FsPermission {
  id         String          @id @default(cuid())
  nodeId     String
  userId     String
  level      PermissionLevel @default(VIEWER)
  grantedBy  String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  node FsNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([nodeId, userId])
  @@index([nodeId])
  @@index([userId])
  @@map("fs_permissions")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  resource  String?     // e.g. "fs_node:clxyz123"
  metadata  Json        @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Social & Messaging ──────────────────────────────────────────────────────

enum UserStatus {
  ONLINE
  AWAY
  DO_NOT_DISTURB
  INVISIBLE
  OFFLINE
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TransferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

model Friendship {
  id        String           @id @default(cuid())
  userId    String
  friendId  String
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user   User @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendUser", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
  @@map("friendships")
}

model Message {
  id             String   @id @default(cuid())
  senderId       String
  receiverId     String?
  groupId        String?
  content        String
  attachmentId   String?  // VFS node ID
  attachmentName String?  // Original filename
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  sender   User       @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User?      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  group    GroupChat?  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([groupId])
  @@index([createdAt])
  @@map("messages")
}

model GroupChat {
  id        String   @id @default(cuid())
  name      String
  avatarUrl String?
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  GroupMember[]
  messages Message[]

  @@index([ownerId])
  @@map("group_chats")
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  joinedAt DateTime @default(now())

  group GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model FileTransfer {
  id           String         @id @default(cuid())
  senderId     String
  receiverId   String
  fileNodeId   String         // VFS node ID being transferred
  fileName     String
  fileSize     Int            @default(0)
  status       TransferStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  completedAt  DateTime?

  sender   User @relation("SentTransfers", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedTransfers", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@map("file_transfers")
}

