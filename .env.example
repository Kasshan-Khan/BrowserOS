# ─── Application ────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=change_me_to_a_random_64_char_hex_string

# ─── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=browseros
POSTGRES_PASSWORD=browseros_secret
POSTGRES_DB=browseros
DATABASE_URL="postgresql://browseros:browseros_secret@localhost:5432/browseros?schema=public"

# ─── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL="redis://:redis_secret@localhost:6379"

# ─── Session ─────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_another_random_64_char_hex_string
SESSION_MAX_AGE=604800   # 7 days in seconds

# ─── CSRF ────────────────────────────────────────────────────────
CSRF_SECRET=change_me_to_yet_another_random_64_char_hex_string

# ─── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=10       # requests per window
RATE_LIMIT_AUTH_WINDOW=900   # 15 minutes in seconds

# ─── Socket.IO ───────────────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
